{
  "extends": "./node_modules/astro/tsconfigs/strict.json",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "paths": {
      "@components/*": ["./src/components/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@data/*": ["./src/data/*"],
      "@i18n/*": ["./src/i18n/*"],
      "@types/*": ["./src/types/*"]
    }
  }
}

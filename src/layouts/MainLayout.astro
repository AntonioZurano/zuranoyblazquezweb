---
import { site } from '../data/site.js';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

// Layout principal. Centraliza el <head> y todo el SEO técnico:
// title, description, canonical, Open Graph, Twitter Card y datos
// estructurados (JSON-LD). Cada página pasa su propio title y description.
interface Props {
  title: string;
  description: string;
  /** Ruta de la imagen para compartir en redes (Open Graph). */
  image?: string;
  /** Texto alternativo de la imagen Open Graph. */
  imageAlt?: string;
  /** Tipo de Open Graph: 'website' (por defecto) o 'article' (blog). */
  ogType?: 'website' | 'article';
  /** Evita la indexación de páginas que no deben aparecer en buscadores. */
  noindex?: boolean;
  /** Objeto(s) JSON-LD adicionales específicos de la página. */
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  image = '/og-default.svg',
  imageAlt = `${site.name} — ${site.tagline}`,
  ogType = 'website',
  noindex = false,
  schema,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, site.url).href;
const fullTitle = title.includes(site.name) ? title : `${title} | ${site.name}`;
const ogImage = new URL(image, site.url).href;

// Datos estructurados de la organización para enriquecer los resultados.
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: site.name,
  url: site.url,
  description: site.description,
  email: site.email,
  telephone: site.phone,
  areaServed: 'ES',
  sameAs: [],
};

// Esquema WebSite para reforzar la identidad del sitio en buscadores.
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.name,
  url: site.url,
  inLanguage: 'es-ES',
};

// Reúne todos los bloques JSON-LD (base + específicos de página).
const extraSchemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const jsonLdBlocks = [organizationSchema, websiteSchema, ...extraSchemas];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />

    <meta name="theme-color" content="#0a4d8c" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <link rel="sitemap" href="/sitemap.xml" />

    {jsonLdBlocks.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}
  </head>
  <body>
    <a class="skip-link" href="#contenido">Saltar al contenido principal</a>
    <Header />
    <main id="contenido" class="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

---
import MainLayout from '@layouts/MainLayout.astro';
import CategoryBadge from '@components/CategoryBadge.astro';
import { site } from '@data/site.js';
import { getUi } from '@i18n/ui';
import { formatDate } from '@i18n/format';
import type { Locale } from '@apptypes/locale';

interface Props {
  title: string;
  description: string;
  category: string;
  author: string;
  pubDate: Date;
  updatedDate?: Date;
  locale?: Locale;
}

const { title, description, category, author, pubDate, updatedDate, locale = 'es' } =
  Astro.props;

const ui = getUi(locale);
const blogBackHref = locale === 'en' ? '/en/blog/' : '/blog/';
const formattedPubDate = formatDate(pubDate, locale);
const isoDate = pubDate.toISOString().split('T')[0];
const authorLine = ui.blogPost.byAuthor.replace('{author}', author);

const postUrl = new URL(Astro.url.pathname, site.url).href;
const logoUrl = new URL('/og-default.png', site.url).href;
const inLanguage = locale === 'en' ? 'en-GB' : 'es-ES';

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  url: postUrl,
  mainEntityOfPage: { '@type': 'WebPage', '@id': postUrl },
  image: logoUrl,
  inLanguage,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: { '@type': 'Organization', name: author, url: site.url },
  publisher: {
    '@type': 'Organization',
    name: site.name,
    url: site.url,
    logo: { '@type': 'ImageObject', url: logoUrl },
  },
};
---

<MainLayout
  lang={locale}
  title={title}
  description={description}
  ogType="article"
  schema={articleSchema}
  publishedTime={pubDate.toISOString()}
  modifiedTime={(updatedDate ?? pubDate).toISOString()}
>
  <article class="post">
    <header class="post__header">
      <div class="container container--narrow">
        <a href={blogBackHref} class="post__back">{ui.blogPost.backToBlog}</a>
        <div class="post__meta">
          <CategoryBadge category={category} />
          <time datetime={isoDate}>{formattedPubDate}</time>
        </div>
        <h1 class="post__title">{title}</h1>
        <p class="post__lead">{description}</p>
        <p class="post__author">{authorLine}</p>
      </div>
    </header>

    <div class="container container--narrow">
      <div class="post__content prose">
        <slot />
      </div>
      {updatedDate && (
        <p class="post__updated">
          {ui.blogPost.updatedOn.replace('{date}', formatDate(updatedDate, locale))}
        </p>
      )}
    </div>
  </article>
</MainLayout>

<style>
  .post__header {
    padding-block: var(--space-6) var(--space-5);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-6);
    background: var(--color-bg-soft);
  }

  .post__back {
    display: inline-block;
    font-size: var(--fs-sm);
    font-weight: 600;
    margin-bottom: var(--space-4);
  }

  .post__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
  }

  .post__title {
    margin-bottom: var(--space-3);
  }

  .post__lead {
    font-size: var(--fs-md);
    color: var(--color-text-soft);
  }

  .post__author {
    margin-top: var(--space-3);
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
  }

  .post__content {
    padding-bottom: var(--space-6);
  }

  .post__updated {
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    padding-bottom: var(--space-6);
  }

  .prose :global(h2) {
    margin-top: var(--space-5);
    margin-bottom: var(--space-3);
    font-size: var(--fs-xl);
  }

  .prose :global(h3) {
    margin-top: var(--space-4);
    margin-bottom: var(--space-2);
  }

  .prose :global(p) {
    margin-bottom: var(--space-3);
    color: var(--color-text-soft);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: var(--space-3);
    color: var(--color-text-soft);
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: var(--space-2);
  }

  .prose :global(li::marker) {
    color: var(--color-primary);
  }

  .prose :global(strong) {
    color: var(--color-text);
  }

  .prose :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
  }
</style>

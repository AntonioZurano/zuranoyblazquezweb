---
const services = [
  {
    icon: 'briefcase',
    title: 'Derecho Mercantil',
    description:
      'Constitución de sociedades, contratos mercantiles, fusiones y adquisiciones. Asesoramiento integral para su empresa en cada etapa de su desarrollo.',
  },
  {
    icon: 'shield',
    title: 'Derecho Laboral',
    description:
      'Gestión de contratos laborales, despidos, ERE y negociación colectiva. Defendemos los intereses de empresas y trabajadores con rigor y eficacia.',
  },
  {
    icon: 'home',
    title: 'Derecho Inmobiliario',
    description:
      'Compraventa de inmuebles, arrendamientos, reclamaciones de comunidades de propietarios y gestión de herencias con bienes inmuebles.',
  },
  {
    icon: 'document',
    title: 'Asesoría Fiscal',
    description:
      'Planificación fiscal para particulares y empresas, declaraciones tributarias, inspecciones de Hacienda y recursos ante la administración.',
  },
  {
    icon: 'users',
    title: 'Derecho de Familia',
    description:
      'Divorcios, separaciones, custodia de menores, herencias y sucesiones. Acompañamos a nuestros clientes en los momentos más delicados.',
  },
  {
    icon: 'globe',
    title: 'Derecho Internacional',
    description:
      'Operaciones transfronterizas, contratos internacionales y asesoramiento en derecho comunitario europeo para empresas con actividad global.',
  },
];

const iconPaths: Record<string, string> = {
  briefcase:
    'M20 7H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2zm-8 9a2 2 0 110-4 2 2 0 010 4zm6-9V6a2 2 0 00-2-2H8a2 2 0 00-2 2v1',
  shield:
    'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  home: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10',
  document:
    'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  users:
    'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
  globe:
    'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9',
};
---

<section id="servicios" class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="inline-block px-3 py-1 text-sm font-medium text-primary-700 bg-primary-100 rounded-full mb-4">
        Áreas de práctica
      </span>
      <h2 class="section-title">Nuestros servicios</h2>
      <p class="section-subtitle">
        Ofrecemos una amplia cobertura jurídica y empresarial adaptada a las necesidades de cada cliente.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        services.map((service) => (
          <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-md transition-shadow duration-300 border border-gray-100 group">
            <div class="w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center mb-6 group-hover:bg-primary-700 transition-colors duration-300">
              <svg
                class="w-6 h-6 text-primary-700 group-hover:text-white transition-colors duration-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[service.icon]} />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-gray-900 mb-3">{service.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{service.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

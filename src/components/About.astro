---
const team = [
  {
    name: 'Carlos Zurano',
    role: 'Socio Director – Derecho Mercantil y Fiscal',
    description:
      'Licenciado en Derecho por la Universidad Complutense de Madrid con Máster en Derecho Fiscal por ICADE. Más de 25 años asesorando a empresas nacionales e internacionales.',
  },
  {
    name: 'Ana Blázquez',
    role: 'Socia – Derecho Laboral y Familia',
    description:
      'Licenciada en Derecho y Máster en Recursos Humanos. Especialista en derecho laboral, con amplia experiencia en negociación colectiva y resolución de conflictos familiares.',
  },
];

const values = [
  {
    title: 'Integridad',
    description: 'Actuamos siempre con honestidad y transparencia, manteniendo los más altos estándares éticos.',
  },
  {
    title: 'Excelencia',
    description: 'Nos comprometemos con la máxima calidad en cada caso, sin excepción.',
  },
  {
    title: 'Cercanía',
    description: 'Tratamos a cada cliente de forma personalizada, escuchando sus necesidades reales.',
  },
  {
    title: 'Eficacia',
    description: 'Buscamos soluciones prácticas y eficientes, maximizando los resultados para nuestros clientes.',
  },
];
---

<section id="nosotros" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- About intro -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center mb-20">
      <div>
        <span class="inline-block px-3 py-1 text-sm font-medium text-primary-700 bg-primary-100 rounded-full mb-4">
          Quiénes somos
        </span>
        <h2 class="section-title">Más de dos décadas<br />a su lado</h2>
        <p class="text-gray-600 leading-relaxed mb-6">
          Zurano y Blázquez nació en 2003 con la vocación de ofrecer un servicio jurídico y empresarial de primer nivel,
          accesible tanto para particulares como para empresas de cualquier tamaño.
        </p>
        <p class="text-gray-600 leading-relaxed mb-8">
          Nuestra filosofía se basa en la confianza mutua, el trato personalizado y el compromiso con los resultados.
          No somos solo abogados; somos sus asesores de confianza a largo plazo.
        </p>
        <a href="#contacto" class="btn-primary">Hablar con un experto</a>
      </div>

      <!-- Values grid -->
      <div class="grid grid-cols-2 gap-4">
        {
          values.map((value) => (
            <div class="bg-gray-50 rounded-xl p-6">
              <h4 class="font-bold text-gray-900 mb-2">{value.title}</h4>
              <p class="text-sm text-gray-600 leading-relaxed">{value.description}</p>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Team -->
    <div>
      <h3 class="text-2xl font-bold text-gray-900 text-center mb-10">El equipo</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-3xl mx-auto">
        {
          team.map((member) => (
            <div class="bg-gray-50 rounded-2xl p-8 text-center">
              <div class="w-20 h-20 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-5">
                <span class="text-2xl font-bold text-primary-700">
                  {member.name
                    .split(' ')
                    .map((n) => n[0])
                    .join('')}
                </span>
              </div>
              <h4 class="text-lg font-bold text-gray-900 mb-1">{member.name}</h4>
              <p class="text-sm font-medium text-primary-700 mb-3">{member.role}</p>
              <p class="text-sm text-gray-600 leading-relaxed">{member.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

---
import type { ContactUi } from '@apptypes/i18n';
import type { ContactFormConfig } from '@apptypes/site';
import type { Locale } from '@apptypes/locale';
import ContactFormPrivacyNotice from '@components/ContactFormPrivacyNotice.astro';
import { getContactFormConsent } from '@i18n/legal/form-consent';

interface Props {
  locale: Locale;
  copy: ContactUi;
  form: ContactFormConfig;
}

const { locale, copy, form } = Astro.props;
const consent = getContactFormConsent(locale);
const honeypotId = `_honey-${locale}`;
const formId = `contact-form-${locale}`;
// Fallback de fecha de consentimiento para navegadores sin JS: se rellena en
// build y el script cliente lo sobrescribe con la hora exacta del envío.
const consentFallbackDate = new Date().toISOString();
---

<div class="contact-form-wrapper card">
  <h2 class="contact-form__title">{copy.formTitle}</h2>
  <p class="contact-form__intro">{copy.formIntro}</p>

  <form id={formId} class="contact-form" method="POST" action={form.endpoint}>
    <input type="hidden" name="_subject" value={form.subject} />
    <input type="hidden" name="_next" value={form.redirectTo} />
    <input type="hidden" name="_captcha" value="false" />
    <input type="hidden" name="_template" value="table" />
    <input type="hidden" name="_replyto" value="" />
    <input type="hidden" name="version_clausula_privacidad" value={consent.clauseVersion} />
    <input type="hidden" name="formulario" value={consent.formId} />
    <input type="hidden" name="fecha_aceptacion_privacidad" value={consentFallbackDate} />

    <div class="visually-hidden" aria-hidden="true">
      <label for={honeypotId}>{copy.honeypotLabel}</label>
      <input type="text" id={honeypotId} name="_honey" tabindex="-1" autocomplete="off" />
    </div>

    <div class="form-row">
      <div class="form-field">
        <label for={`nombre-${locale}`}>{copy.nameLabel}</label>
        <input type="text" id={`nombre-${locale}`} name="nombre" autocomplete="name" maxlength="120" required aria-required="true" />
      </div>
      <div class="form-field">
        <label for={`empresa-${locale}`}>{copy.companyLabel}</label>
        <input type="text" id={`empresa-${locale}`} name="empresa" autocomplete="organization" />
      </div>
    </div>

    <div class="form-row">
      <div class="form-field">
        <label for={`email-${locale}`}>{copy.emailFieldLabel}</label>
        <input type="email" id={`email-${locale}`} name="email" autocomplete="email" maxlength="160" required aria-required="true" />
      </div>
      <div class="form-field">
        <label for={`telefono-${locale}`}>{copy.phoneFieldLabel}</label>
        <input type="tel" id={`telefono-${locale}`} name="telefono" autocomplete="tel" />
      </div>
    </div>

    <div class="form-field">
      <label for={`servicio-${locale}`}>{copy.serviceLabel}</label>
      <select id={`servicio-${locale}`} name="servicio">
        <option value="">{copy.servicePlaceholder}</option>
        {copy.services.map((option) => (
          <option value={option.value}>{option.label}</option>
        ))}
      </select>
    </div>

    <div class="form-field">
      <label for={`mensaje-${locale}`}>{copy.messageLabel}</label>
      <textarea id={`mensaje-${locale}`} name="mensaje" rows="5" maxlength="3000" required aria-required="true" />
    </div>

    <ContactFormPrivacyNotice locale={locale} />

    <div class="form-field form-field--check">
      <input
        type="checkbox"
        id={`privacidad-${locale}`}
        name="aceptacion_politica_privacidad"
        value={consent.acceptanceValue}
        required
        aria-required="true"
      />
      <label for={`privacidad-${locale}`}>
        {copy.privacyAcceptBefore}
        <a href={copy.privacyHref} target="_blank" rel="noopener noreferrer">{copy.privacyLink}</a>. *
      </label>
    </div>

    <button type="submit" class="btn btn--primary contact-form__submit">{copy.submit}</button>
  </form>
</div>

<script define:vars={{ formId }}>
  const contactForm = document.getElementById(formId);

  contactForm?.addEventListener('submit', () => {
    const dateField = contactForm.querySelector('input[name="fecha_aceptacion_privacidad"]');
    if (dateField instanceof HTMLInputElement) {
      dateField.value = new Date().toISOString();
    }

    // Usa el email introducido como dirección de respuesta en Formsubmit.
    const emailField = contactForm.querySelector('input[name="email"]');
    const replyToField = contactForm.querySelector('input[name="_replyto"]');
    if (emailField instanceof HTMLInputElement && replyToField instanceof HTMLInputElement) {
      replyToField.value = emailField.value;
    }

    // Evita el doble envío mientras se procesa la petición.
    const submitBtn = contactForm.querySelector('button[type="submit"]');
    if (submitBtn instanceof HTMLButtonElement) {
      submitBtn.disabled = true;
      submitBtn.setAttribute('aria-busy', 'true');
    }
  });
</script>

<style>
  .contact-form__title {
    font-size: var(--fs-lg);
    margin-bottom: var(--space-2);
  }

  .contact-form__intro {
    font-size: var(--fs-sm);
    margin-bottom: var(--space-4);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .form-field label {
    font-size: var(--fs-sm);
    font-weight: 600;
    color: var(--color-text);
  }

  .form-field input,
  .form-field select,
  .form-field textarea {
    font: inherit;
    font-size: var(--fs-sm);
    color: var(--color-text);
    padding: 0.7rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-soft);
    transition: border-color var(--transition), box-shadow var(--transition);
    width: 100%;
  }

  .form-field input:focus-visible,
  .form-field select:focus-visible,
  .form-field textarea:focus-visible {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: var(--focus-input);
    background: var(--color-input-bg-focus);
  }

  .form-field textarea {
    resize: vertical;
  }

  .form-field--check {
    flex-direction: row;
    align-items: flex-start;
    gap: var(--space-2);
  }

  .form-field--check input {
    width: auto;
    margin-top: 0.2rem;
  }

  .form-field--check label {
    font-weight: 400;
    color: var(--color-text-soft);
    font-size: var(--fs-sm);
  }

  .contact-form__submit {
    width: 100%;
    margin-top: var(--space-4);
  }

  @media (max-width: 820px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>

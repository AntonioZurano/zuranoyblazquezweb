---
import LegalDocumentContent from '@components/LegalDocumentContent.astro';
import { getPrivacyPolicySections } from '@i18n/legal/privacy-policy';
import type { Locale } from '@apptypes/locale';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const sections = getPrivacyPolicySections(locale);
---

<LegalDocumentContent sections={sections} />

---
import LegalDocumentContent from '@components/LegalDocumentContent.astro';
import { getLegalNoticeSections } from '@i18n/legal/legal-notice';
import type { Locale } from '@types/locale';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const sections = getLegalNoticeSections(locale);
---

<LegalDocumentContent sections={sections} />

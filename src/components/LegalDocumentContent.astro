---
import { site } from '@data/site.ts';
import type { LegalSection } from '@types/legal';
import InlineCodeText from './InlineCodeText.astro';

interface Props {
  sections: LegalSection[];
}

const { sections } = Astro.props;
---

{
  sections.map((section) => (
    <>
      <h2>
        <InlineCodeText text={section.title} />
      </h2>
      {section.blocks.map((block) => {
        if (block.type === 'p') {
          return (
            <p>
              <InlineCodeText text={block.text} />
            </p>
          );
        }

        if (block.type === 'h3') {
          return (
            <h3>
              <InlineCodeText text={block.text} />
            </h3>
          );
        }

        if (block.type === 'labeled') {
          return (
            <p>
              <strong>{block.label}</strong>{' '}
              <InlineCodeText text={block.text} />
            </p>
          );
        }

        if (block.type === 'ul') {
          return (
            <ul>
              {block.items.map((item) => (
                <li>
                  <InlineCodeText text={item} />
                </li>
              ))}
            </ul>
          );
        }

        if (block.type === 'p-email') {
          return (
            <p>
              {block.before}
              <a href={`mailto:${site.email}`}>{site.email}</a>
              {block.after}
            </p>
          );
        }

        if (block.type === 'p-link') {
          return (
            <p>
              {block.before}
              <a href={block.href} rel={block.external ? 'noopener noreferrer' : undefined}>
                {block.linkText}
              </a>
              {block.after}
            </p>
          );
        }

        if (block.type === 'address') {
          return (
            <p>
              {block.lines.map((line, index) => (
                <>
                  {index > 0 && <br />}
                  <strong>{line}</strong>
                </>
              ))}
              {block.email && (
                <>
                  <br />
                  <a href={`mailto:${site.email}`}>{site.email}</a>
                </>
              )}
            </p>
          );
        }

        if (block.type === 'table') {
          return (
            <div class="legal-table-wrap">
              <table class="legal-table">
                <thead>
                  <tr>
                    {block.headers.map((header) => (
                      <th scope="col">{header}</th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {block.rows.map((row) => (
                    <tr>
                      {row.map((cell) => (
                        <td>
                          <InlineCodeText text={cell} />
                        </td>
                      ))}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          );
        }

        return null;
      })}
    </>
  ))
}

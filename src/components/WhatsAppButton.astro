---
import { getLocaleFromPath } from '@i18n/routes';
import { getUi } from '@i18n/ui';
import { getWhatsAppHref } from '@i18n/whatsapp';

// Botón flotante de contacto por WhatsApp. Enlace oficial wa.me, sin plugins,
// SDK ni scripts externos: solo un <a> con SVG inline. El idioma se detecta
// por la ruta y determina el mensaje predefinido (fallback a español).
const locale = getLocaleFromPath(Astro.url.pathname);
const labels = getUi(locale).whatsapp;
const href = getWhatsAppHref(locale);
---

<a
  class="whatsapp-button"
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={labels.ariaLabel}
  title={labels.title}
>
  <svg
    class="whatsapp-button__icon"
    width="30"
    height="30"
    viewBox="0 0 24 24"
    fill="currentColor"
    aria-hidden="true"
    focusable="false"
  >
    <path
      d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.742-.958zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.166-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.612-.916-2.207-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"
    ></path>
  </svg>
</a>

<style>
  .whatsapp-button {
    position: fixed;
    right: var(--space-4);
    bottom: var(--space-4);
    z-index: 900;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: var(--radius-full);
    background: var(--color-whatsapp);
    color: #ffffff;
    box-shadow: var(--shadow);
    transition:
      background-color var(--transition),
      transform var(--transition),
      box-shadow var(--transition);
  }

  .whatsapp-button:hover {
    background: var(--color-whatsapp-hover);
    transform: translateY(-2px);
    box-shadow: 0 12px 28px rgba(18, 140, 87, 0.35);
  }

  .whatsapp-button:focus-visible {
    outline: 3px solid var(--color-primary);
    outline-offset: 3px;
  }

  .whatsapp-button__icon {
    display: block;
  }

  @media (max-width: 820px) {
    .whatsapp-button {
      right: var(--space-3);
      bottom: calc(var(--space-3) + env(safe-area-inset-bottom, 0px));
      width: 54px;
      height: 54px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .whatsapp-button {
      transition: none;
    }

    .whatsapp-button:hover {
      transform: none;
    }
  }
</style>

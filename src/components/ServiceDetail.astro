---
import Hero from './Hero.astro';
import SectionTitle from './SectionTitle.astro';
import CTA from './CTA.astro';
import Icon from './Icon.astro';
import { getUi } from '@i18n/ui';
import type { Locale } from '@types/locale';
import type { FaqItem, ServiceFeature } from '@types/service';

interface Props {
  eyebrow: string;
  h1: string;
  subtitle: string;
  introTitle: string;
  introText: string;
  benefits: string[];
  features: ServiceFeature[];
  faq?: FaqItem[];
  locale?: Locale;
}

const {
  eyebrow,
  h1,
  subtitle,
  introTitle,
  introText,
  benefits,
  features,
  faq = [],
  locale = 'es',
} = Astro.props;

const sd = getUi(locale).serviceDetail;
---

<Hero
  eyebrow={eyebrow}
  subtitle={subtitle}
  variant="compact"
  primaryCta={{ label: sd.primaryCta, href: sd.contactHref }}
  secondaryCta={{ label: sd.secondaryCta, href: sd.servicesHref }}
>
  <h1>{h1}</h1>
</Hero>

<section class="section">
  <div class="container intro-grid">
    <div>
      <SectionTitle eyebrow={sd.introEyebrow} title={introTitle} />
      <p class="lead">{introText}</p>
    </div>
    <div class="intro-grid__benefits card">
      <h3>{sd.benefitsTitle}</h3>
      <ul class="check-list">
        {benefits.map((benefit) => <li>{benefit}</li>)}
      </ul>
    </div>
  </div>
</section>

<section class="section section--soft">
  <div class="container">
    <SectionTitle eyebrow={sd.featuresEyebrow} title={sd.featuresTitle} align="center" />
    <div class="grid grid--cards">
      {features.map((feature) => (
        <article class="feature card">
          <span class="feature__icon" aria-hidden="true">
            <Icon name={feature.icon} size={24} />
          </span>
          <h3>{feature.title}</h3>
          <p>{feature.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

{
  faq.length > 0 && (
    <section class="section">
      <div class="container container--narrow">
        <SectionTitle eyebrow={sd.faqEyebrow} title={sd.faqTitle} />
        <div class="faq">
          {faq.map((item) => (
            <details class="faq__item">
              <summary class="faq__question">{item.question}</summary>
              <p class="faq__answer">{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )
}

<CTA locale={locale} />

<style>
  .intro-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: var(--space-6);
    align-items: start;
  }

  .intro-grid__benefits h3 {
    margin-bottom: var(--space-4);
  }

  .feature__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-sm);
    background: var(--color-bg-alt);
    color: var(--color-primary);
    margin-bottom: var(--space-3);
  }

  .feature h3 {
    margin-bottom: var(--space-2);
    font-size: var(--fs-md);
  }

  .feature p {
    font-size: var(--fs-sm);
  }

  .faq {
    display: grid;
    gap: var(--space-3);
  }

  .faq__item {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-card);
    padding: var(--space-4);
  }

  .faq__question {
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-3);
  }

  .faq__question::after {
    content: '+';
    font-size: var(--fs-lg);
    color: var(--color-primary);
    transition: transform var(--transition);
  }

  .faq__item[open] .faq__question::after {
    transform: rotate(45deg);
  }

  .faq__answer {
    margin-top: var(--space-3);
    font-size: var(--fs-sm);
  }

  @media (max-width: 820px) {
    .intro-grid {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
  }
</style>

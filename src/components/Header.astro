---
import { site } from '@data/site.js';
import { getLocaleFromPath } from '@i18n/routes';
import { getUi } from '@i18n/ui';
import Icon from './Icon.astro';
import ThemeToggle from './ThemeToggle.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';

const currentPath = Astro.url.pathname;
const locale = getLocaleFromPath(currentPath);
const ui = getUi(locale);
const mainNav = ui.mainNav;
const homeHref = locale === 'en' ? '/en/' : '/';
const contactHref = locale === 'en' ? '/en/contact/' : '/contacto/';

const isActive = (href: string) => {
  if (href === '/' || href === '/en/') {
    return currentPath === href || (href === '/en/' && currentPath === '/en');
  }
  return currentPath === href || currentPath.startsWith(href);
};

const isCurrent = (href: string) => currentPath === href;
---

<header class="site-header">
  <div class="container site-header__inner">
    <div class="site-header__start">
      <a href={homeHref} class="brand" aria-label={`${site.name} — ${ui.brandHome}`}>
        <span class="brand__mark" aria-hidden="true">ZB</span>
        <span class="brand__text">
          <span class="brand__name">{site.name}</span>
          <span class="brand__tagline">{ui.tagline}</span>
        </span>
      </a>
      <div class="site-header__controls">
        <LanguageSwitcher />
        <ThemeToggle locale={locale} />
      </div>
    </div>

    <div class="site-header__actions">
      <button
        class="nav-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="primary-nav"
        aria-label={ui.navToggleOpen}
        data-open-label={ui.navToggleOpen}
        data-close-label={ui.navToggleClose}
      >
        <span class="nav-toggle__bar"></span>
        <span class="nav-toggle__bar"></span>
        <span class="nav-toggle__bar"></span>
      </button>

      <nav id="primary-nav" class="primary-nav" aria-label={ui.navAria}>
        <ul class="primary-nav__list">
          {
            mainNav.map((item) =>
              item.children ? (
                <li class="has-submenu">
                  <a
                    href={item.href}
                    class:list={['nav-link', { 'is-active': isActive(item.href) }]}
                    aria-haspopup="true"
                    aria-expanded="false"
                    aria-current={isCurrent(item.href) ? 'page' : undefined}
                  >
                    {item.label}
                    <Icon name="arrow" size={14} class="nav-link__caret" />
                  </a>
                  <ul class="submenu">
                    {item.children.map((child) => (
                      <li>
                        <a
                          href={child.href}
                          class:list={['submenu__link', { 'is-active': isActive(child.href) }]}
                          aria-current={isCurrent(child.href) ? 'page' : undefined}
                        >
                          {child.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </li>
              ) : (
                <li>
                  <a
                    href={item.href}
                    class:list={['nav-link', { 'is-active': isActive(item.href) }]}
                    aria-current={isCurrent(item.href) ? 'page' : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              )
            )
          }
          <li class="primary-nav__cta">
            <a href={contactHref} class="btn btn--primary">{ui.navContact}</a>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-header-bg);
    backdrop-filter: saturate(180%) blur(8px);
    border-bottom: 1px solid var(--color-border);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    min-height: 72px;
  }

  .site-header__start {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    min-width: 0;
  }

  .site-header__controls {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    flex-shrink: 0;
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  /* ---- Marca ---- */
  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-text);
  }

  .brand__mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: var(--radius-sm);
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 130%);
    color: var(--color-on-primary);
    font-weight: 800;
    font-size: var(--fs-sm);
    letter-spacing: 0.02em;
  }

  .brand__text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }

  .brand__name {
    font-weight: 700;
    font-size: var(--fs-md);
  }

  .brand__tagline {
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
  }

  /* ---- Navegación ---- */
  .primary-nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.6rem 0.85rem;
    border-radius: var(--radius-sm);
    color: var(--color-text-soft);
    font-weight: 500;
    font-size: var(--fs-sm);
  }

  .nav-link:hover,
  .nav-link.is-active {
    color: var(--color-primary);
    background: var(--color-bg-soft);
  }

  .nav-link__caret {
    transition: transform var(--transition);
    transform: rotate(90deg);
  }

  /* ---- Submenú (escritorio: hover) ---- */
  .has-submenu {
    position: relative;
  }

  .submenu {
    list-style: none;
    margin: 0;
    padding: var(--space-2);
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    min-width: 260px;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    opacity: 0;
    visibility: hidden;
    transform: translateY(6px);
    transition: all var(--transition);
  }

  .has-submenu:hover .submenu,
  .has-submenu:focus-within .submenu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .submenu__link {
    display: block;
    padding: 0.55rem 0.75rem;
    border-radius: var(--radius-sm);
    color: var(--color-text-soft);
    font-size: var(--fs-sm);
  }

  .submenu__link:hover,
  .submenu__link.is-active {
    background: var(--color-bg-soft);
    color: var(--color-primary);
  }

  .primary-nav__cta {
    margin-left: var(--space-2);
  }

  /* ---- Botón menú móvil ---- */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 0;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    cursor: pointer;
  }

  .nav-toggle__bar {
    display: block;
    width: 22px;
    height: 2px;
    margin-inline: auto;
    background: var(--color-text);
    transition: transform var(--transition), opacity var(--transition);
  }

  /* ---- Responsive ---- */
  @media (max-width: 920px) {
    .nav-toggle {
      display: flex;
    }

    .primary-nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--color-header-bg);
      border-bottom: 1px solid var(--color-border);
      box-shadow: var(--shadow);
      max-height: 0;
      overflow: hidden;
      transition: max-height 280ms ease;
    }

    .primary-nav.is-open {
      max-height: calc(100vh - 72px);
      overflow-y: auto;
    }

    .primary-nav__list {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: var(--space-3);
    }

    .nav-link {
      padding: 0.85rem;
      justify-content: space-between;
      font-size: var(--fs-base);
    }

    .submenu {
      position: static;
      opacity: 1;
      visibility: visible;
      transform: none;
      box-shadow: none;
      border: none;
      border-left: 2px solid var(--color-border);
      border-radius: 0;
      margin: 0 0 var(--space-2) var(--space-3);
      padding: 0;
      display: none;
    }

    .has-submenu.is-expanded .submenu {
      display: block;
    }

    .has-submenu.is-expanded .nav-link__caret {
      transform: rotate(-90deg);
    }

    .primary-nav__cta {
      margin: var(--space-2) 0 0;
    }

    .primary-nav__cta .btn {
      width: 100%;
    }
  }

  .nav-toggle[aria-expanded='true'] .nav-toggle__bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-toggle[aria-expanded='true'] .nav-toggle__bar:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle[aria-expanded='true'] .nav-toggle__bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
</style>

<script>
  const header = document.querySelector('.site-header');
  const toggle = header?.querySelector<HTMLButtonElement>('.nav-toggle');
  const nav = header?.querySelector<HTMLElement>('.primary-nav');

  toggle?.addEventListener('click', () => {
    const open = nav?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(Boolean(open)));
    const openLabel = toggle.dataset.openLabel ?? 'Open navigation menu';
    const closeLabel = toggle.dataset.closeLabel ?? 'Close navigation menu';
    toggle.setAttribute('aria-label', open ? closeLabel : openLabel);
  });

  const mql = window.matchMedia('(max-width: 920px)');
  header?.querySelectorAll<HTMLElement>('.has-submenu > .nav-link').forEach((link) => {
    link.addEventListener('click', (event) => {
      if (!mql.matches) return;
      const parent = link.parentElement;
      if (!parent) return;
      if (!parent.classList.contains('is-expanded')) {
        event.preventDefault();
        parent.classList.add('is-expanded');
        link.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>

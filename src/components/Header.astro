---
const navLinks = [
  { href: '#inicio', label: 'Inicio' },
  { href: '#servicios', label: 'Servicios' },
  { href: '#nosotros', label: 'Nosotros' },
  { href: '#contacto', label: 'Contacto' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="#inicio" class="flex items-center space-x-2">
        <span class="text-xl font-bold text-primary-800 tracking-tight">
          Zurano <span class="text-gold-500">&amp;</span> Blázquez
        </span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center space-x-8" aria-label="Navegación principal">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="text-gray-600 hover:text-primary-700 font-medium transition-colors duration-200 text-sm"
            >
              {link.label}
            </a>
          ))
        }
        <a
          href="#contacto"
          class="btn-primary text-sm py-2 px-4"
        >
          Consulta gratuita
        </a>
      </nav>

      <!-- Mobile menu button -->
      <button
        id="menu-toggle"
        class="md:hidden p-2 rounded-md text-gray-600 hover:text-primary-700 hover:bg-gray-100 transition-colors"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100">
    <div class="px-4 py-4 space-y-3">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="block text-gray-600 hover:text-primary-700 font-medium py-2 transition-colors"
          >
            {link.label}
          </a>
        ))
      }
      <a href="#contacto" class="btn-primary text-sm py-2 w-full text-center block">
        Consulta gratuita
      </a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  document.querySelectorAll('#mobile-menu a').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>

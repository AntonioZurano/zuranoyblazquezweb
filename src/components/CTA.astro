---
import { site } from '../data/site.js';

// Bloque de llamada a la acción reutilizable, normalmente al final de página.
interface Props {
  title?: string;
  text?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  title = '¿Hablamos de tu proyecto?',
  text = 'Cuéntanos qué necesita tu empresa y te propondremos la solución más sencilla, útil y rentable. Sin compromiso.',
  primaryLabel = 'Solicitar información',
  primaryHref = '/contacto/',
  secondaryLabel = 'Llamar ahora',
  secondaryHref = `tel:${site.phoneHref}`,
} = Astro.props;
---

<section class="cta">
  <div class="container cta__inner">
    <div class="cta__content">
      <h2 class="cta__title">{title}</h2>
      <p class="cta__text">{text}</p>
    </div>
    <div class="cta__actions">
      <a href={primaryHref} class="btn btn--accent">{primaryLabel}</a>
      {secondaryLabel && <a href={secondaryHref} class="btn btn--ghost-light">{secondaryLabel}</a>}
    </div>
  </div>
</section>

<style>
  .cta {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    color: #fff;
  }

  .cta__inner {
    padding-block: clamp(var(--space-6), 8vw, var(--space-7));
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
  }

  .cta__content {
    max-width: 56ch;
  }

  .cta__title {
    color: #fff;
    margin: 0;
  }

  .cta__text {
    color: rgba(255, 255, 255, 0.88);
    margin-top: var(--space-3);
  }

  .cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  @media (max-width: 720px) {
    .cta__actions .btn {
      flex: 1 1 auto;
    }
  }
</style>

---
import { site } from '@data/site.ts';
import { getDataCollectionCopy } from '@i18n/legal/data-collection';
import type { Locale } from '@types/locale';

interface Props {
  locale: Locale;
  variant: 'form' | 'page';
  showTitle?: boolean;
}

const { locale, variant, showTitle = variant === 'page' } = Astro.props;
const copy = getDataCollectionCopy(locale);
---

<div
  class:list={[
    'legal-data-collection',
    variant === 'form' && 'legal-data-collection--form',
    variant === 'page' && 'legal-data-collection--page',
  ]}
>
  {showTitle && <h2>{copy.sectionTitle}</h2>}

  <div class="legal-data-collection__body">
    {copy.bodyParagraphs.map((paragraph) => (
      <p>{paragraph}</p>
    ))}

    <p>
      {copy.rightsParagraphBeforeEmail}
      <a href={`mailto:${site.email}`}>{site.email}</a>
      {copy.rightsParagraphAfterEmail}
      <a href="https://www.aepd.es" rel="noopener noreferrer">aepd.es</a>).
    </p>
  </div>

  {
    variant === 'form' ? (
      <fieldset class="legal-data-collection__consent">
        <legend>{copy.marketingConsentLegend}</legend>
        <div class="legal-data-collection__options">
          <label class="legal-data-collection__option">
            <input type="radio" name="autorizacion_comercial" value="si" />
            {copy.marketingYes}
          </label>
          <label class="legal-data-collection__option">
            <input type="radio" name="autorizacion_comercial" value="no" />
            {copy.marketingNo}
          </label>
        </div>
      </fieldset>
    ) : (
      <p class="legal-data-collection__static-consent">
        {copy.marketingConsentLegend}
      </p>
    )
  }
</div>

<style>
  .legal-data-collection--form {
    margin-top: var(--space-4);
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-alt);
    border-left: 3px solid var(--color-accent);
    border-radius: var(--radius-sm);
  }

  .legal-data-collection--form .legal-data-collection__body {
    max-height: 16rem;
    overflow-y: auto;
    padding-right: var(--space-2);
  }

  .legal-data-collection--page h2 {
    margin-top: var(--space-5);
    margin-bottom: var(--space-3);
    font-size: var(--fs-lg);
  }

  .legal-data-collection__body p {
    margin-bottom: var(--space-3);
    font-size: var(--fs-sm);
    color: var(--color-text-soft);
    line-height: 1.6;
  }

  .legal-data-collection--page .legal-data-collection__body p {
    font-size: inherit;
    color: inherit;
  }

  .legal-data-collection__consent {
    margin: var(--space-4) 0 0;
    padding: 0;
    border: 0;
  }

  .legal-data-collection__consent legend {
    font-size: var(--fs-sm);
    color: var(--color-text-soft);
    line-height: 1.6;
    margin-bottom: var(--space-3);
    padding: 0;
  }

  .legal-data-collection__options {
    display: flex;
    gap: var(--space-4);
  }

  .legal-data-collection__option {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--fs-sm);
    color: var(--color-text);
    cursor: pointer;
  }

  .legal-data-collection__option input {
    width: auto;
    margin: 0;
  }

  .legal-data-collection__static-consent {
    font-size: var(--fs-sm);
    color: var(--color-text-soft);
    line-height: 1.6;
  }

  .legal-data-collection--page .legal-data-collection__static-consent {
    font-size: inherit;
    color: inherit;
  }
</style>

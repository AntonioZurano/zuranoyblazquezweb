---
---

<section id="inicio" class="relative min-h-screen flex items-center pt-16 overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-primary-950 via-primary-900 to-primary-800"></div>

  <!-- Decorative pattern -->
  <div class="absolute inset-0 opacity-10">
    <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="0.5" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)" />
    </svg>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="max-w-3xl">
      <span class="inline-block px-3 py-1 text-sm font-medium text-gold-400 bg-gold-400/10 rounded-full border border-gold-400/20 mb-6">
        Asesoría Jurídica y Empresarial
      </span>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
        Su confianza,<br />
        <span class="text-gold-400">nuestra prioridad</span>
      </h1>
      <p class="text-lg sm:text-xl text-primary-200 leading-relaxed mb-10 max-w-2xl">
        En Zurano y Blázquez llevamos más de 20 años ofreciendo asesoramiento jurídico y empresarial integral,
        con un enfoque personalizado y resultados probados para empresas y particulares.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="#contacto" class="btn-primary text-base py-3 px-8">
          Consulta gratuita
        </a>
        <a href="#servicios" class="btn-secondary border-white/40 text-white hover:bg-white/10 hover:border-white text-base py-3 px-8">
          Nuestros servicios
        </a>
      </div>

      <!-- Stats -->
      <div class="mt-16 grid grid-cols-2 sm:grid-cols-3 gap-8 border-t border-white/10 pt-10">
        <div>
          <p class="text-3xl font-bold text-white">+20</p>
          <p class="text-sm text-primary-300 mt-1">Años de experiencia</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-white">+500</p>
          <p class="text-sm text-primary-300 mt-1">Clientes satisfechos</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-white">95%</p>
          <p class="text-sm text-primary-300 mt-1">Casos resueltos</p>
        </div>
      </div>
    </div>
  </div>
</section>

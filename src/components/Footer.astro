---
import { site, services } from '@data/site.js';
import { getLocaleFromPath } from '@i18n/routes';
import { getUi } from '@i18n/ui';
import { servicesEn } from '@i18n/en/data';
import Icon from './Icon.astro';

const currentPath = Astro.url.pathname;
const locale = getLocaleFromPath(currentPath);
const ui = getUi(locale);
const year = new Date().getFullYear();
const homeHref = locale === 'en' ? '/en/' : '/';

const footerServices =
  locale === 'en'
    ? servicesEn.map((s) => ({ label: s.title, href: s.href }))
    : services.map((s) => ({ label: s.title, href: s.href }));

const footerCompany = [
  { label: ui.footer.aboutUs, href: locale === 'en' ? '/en/company/' : '/empresa/' },
  { label: ui.footer.services, href: locale === 'en' ? '/en/services/' : '/servicios/' },
  { label: ui.footer.blog, href: locale === 'en' ? '/en/blog/' : '/blog/' },
  { label: ui.footer.contact, href: locale === 'en' ? '/en/contact/' : '/contacto/' },
];

const footerLegal = [
  { label: ui.footer.legalNotice, href: locale === 'en' ? '/en/legal-notice/' : '/aviso-legal/' },
  {
    label: ui.footer.privacyPolicy,
    href: locale === 'en' ? '/en/privacy-policy/' : '/politica-de-privacidad/',
  },
  {
    label: ui.footer.cookiesPolicy,
    href: locale === 'en' ? '/en/cookies-policy/' : '/politica-de-cookies/',
  },
];
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <a href={homeHref} class="footer-brand" aria-label={`${site.name} — ${ui.brandHome}`}>
        <span class="footer-brand__mark" aria-hidden="true">ZB</span>
        <span class="footer-brand__name">{site.name}</span>
      </a>
      <p class="site-footer__desc">{ui.siteDescription}</p>
      <ul class="site-footer__contact">
        <li>
          <Icon name="mail" size={18} />
          <a href={`mailto:${site.email}`}>{site.email}</a>
        </li>
        <li>
          <Icon name="phone" size={18} />
          <a href={`tel:${site.phoneHref}`}>{site.phone}</a>
        </li>
        <li>
          <Icon name="clock" size={18} />
          <span>{ui.schedule}</span>
        </li>
      </ul>
    </div>

    <nav class="site-footer__nav" aria-label={ui.footer.servicesTitle}>
      <h2 class="site-footer__title">{ui.footer.servicesTitle}</h2>
      <ul>
        {footerServices.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>

    <nav class="site-footer__nav" aria-label={ui.footer.companyTitle}>
      <h2 class="site-footer__title">{ui.footer.companyTitle}</h2>
      <ul>
        {footerCompany.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>

    <nav class="site-footer__nav" aria-label={ui.footer.legalTitle}>
      <h2 class="site-footer__title">{ui.footer.legalTitle}</h2>
      <ul>
        {footerLegal.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>
  </div>

  <div class="site-footer__bottom">
    <div class="container site-footer__bottom-inner">
      <p>© {year} {site.legalName}. {ui.footer.copyright}</p>
      <p>{ui.tagline} · {site.domain}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-footer-bg);
    color: var(--color-footer-text);
    margin-top: auto;
  }

  .site-footer a {
    color: var(--color-footer-text);
  }

  .site-footer a:hover {
    color: var(--color-footer-heading);
  }

  .site-footer__inner {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: var(--space-5);
    padding-block: var(--space-7);
  }

  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-footer-heading);
  }

  .footer-brand__mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: var(--radius-sm);
    background: linear-gradient(135deg, var(--color-primary-light) 0%, var(--color-accent) 130%);
    color: var(--color-on-primary);
    font-weight: 800;
    font-size: var(--fs-sm);
  }

  .footer-brand__name {
    font-weight: 700;
    font-size: var(--fs-md);
    color: var(--color-footer-heading);
  }

  .site-footer__desc {
    margin: var(--space-3) 0 var(--space-4);
    color: var(--color-footer-text-soft);
    font-size: var(--fs-sm);
    max-width: 42ch;
  }

  .site-footer__contact {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-2);
  }

  .site-footer__contact li {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--fs-sm);
    color: var(--color-footer-text-soft);
  }

  .site-footer__contact svg {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .site-footer__title {
    font-size: var(--fs-sm);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-footer-heading);
    margin: 0 0 var(--space-3);
  }

  .site-footer__nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-2);
  }

  .site-footer__nav a {
    font-size: var(--fs-sm);
    color: var(--color-footer-text-soft);
  }

  .site-footer__bottom {
    border-top: 1px solid var(--color-footer-border);
  }

  .site-footer__bottom-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--space-2);
    padding-block: var(--space-4);
    font-size: var(--fs-xs);
    color: var(--color-footer-text-muted);
  }

  .site-footer__bottom-inner p {
    color: var(--color-footer-text-muted);
    margin: 0;
  }

  @media (max-width: 920px) {
    .site-footer__inner {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 560px) {
    .site-footer__inner {
      grid-template-columns: 1fr;
    }
  }
</style>

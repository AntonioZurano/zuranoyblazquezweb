---
---

<footer class="bg-gray-900 text-gray-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <h3 class="text-white text-xl font-bold mb-3">
          Zurano <span class="text-gold-400">&amp;</span> Blázquez
        </h3>
        <p class="text-sm text-gray-400 leading-relaxed">
          Asesoría jurídica y empresarial de confianza. Más de 20 años protegiendo los intereses de nuestros clientes.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-white font-semibold mb-4">Navegación</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="#inicio" class="hover:text-white transition-colors">Inicio</a></li>
          <li><a href="#servicios" class="hover:text-white transition-colors">Servicios</a></li>
          <li><a href="#nosotros" class="hover:text-white transition-colors">Nosotros</a></li>
          <li><a href="#contacto" class="hover:text-white transition-colors">Contacto</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h4 class="text-white font-semibold mb-4">Contacto</h4>
        <ul class="space-y-2 text-sm text-gray-400">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 shrink-0 text-gold-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Calle Mayor 10, 28013 Madrid, España</span>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0 text-gold-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+34910000000" class="hover:text-white transition-colors">+34 91 000 00 00</a>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0 text-gold-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:info@zuranoyblazquez.com" class="hover:text-white transition-colors">info@zuranoyblazquez.com</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-10 pt-6 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-sm text-gray-500">
        &copy; {new Date().getFullYear()} Zurano y Blázquez. Todos los derechos reservados.
      </p>
      <p class="text-xs text-gray-600">
        Desarrollado con <a href="https://astro.build" class="hover:text-gray-400 transition-colors" target="_blank" rel="noopener noreferrer">Astro</a>
      </p>
    </div>
  </div>
</footer>

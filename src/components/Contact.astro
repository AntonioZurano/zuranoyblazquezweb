---
---

<section id="contacto" class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="inline-block px-3 py-1 text-sm font-medium text-primary-700 bg-primary-100 rounded-full mb-4">
        Contacto
      </span>
      <h2 class="section-title">¿Cómo podemos ayudarle?</h2>
      <p class="section-subtitle">
        Póngase en contacto con nosotros y le responderemos en el menor tiempo posible.
        La primera consulta es completamente gratuita.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
      <!-- Contact Info -->
      <div class="lg:col-span-2 space-y-8">
        <div>
          <h3 class="text-lg font-semibold text-gray-900 mb-6">Información de contacto</h3>
          <ul class="space-y-5">
            <li class="flex items-start gap-4">
              <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <p class="font-medium text-gray-900">Dirección</p>
                <p class="text-sm text-gray-600 mt-1">Calle Mayor 10, 1ª planta<br />28013 Madrid, España</p>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <p class="font-medium text-gray-900">Teléfono</p>
                <a href="tel:+34910000000" class="text-sm text-primary-700 hover:text-primary-800 mt-1 block">+34 91 000 00 00</a>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="font-medium text-gray-900">Email</p>
                <a href="mailto:info@zuranoyblazquez.com" class="text-sm text-primary-700 hover:text-primary-800 mt-1 block">info@zuranoyblazquez.com</a>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <p class="font-medium text-gray-900">Horario</p>
                <p class="text-sm text-gray-600 mt-1">Lun – Vie: 9:00 – 19:00<br />Sáb: 10:00 – 14:00</p>
              </div>
            </li>
          </ul>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="lg:col-span-3">
        <form
          id="contact-form"
          class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 space-y-6"
          novalidate
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="nombre" class="block text-sm font-medium text-gray-700 mb-2">Nombre *</label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                required
                autocomplete="given-name"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-colors"
                placeholder="Su nombre"
              />
            </div>
            <div>
              <label for="apellidos" class="block text-sm font-medium text-gray-700 mb-2">Apellidos *</label>
              <input
                type="text"
                id="apellidos"
                name="apellidos"
                required
                autocomplete="family-name"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-colors"
                placeholder="Sus apellidos"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email *</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-colors"
                placeholder="su@email.com"
              />
            </div>
            <div>
              <label for="telefono" class="block text-sm font-medium text-gray-700 mb-2">Teléfono</label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                autocomplete="tel"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-colors"
                placeholder="+34 600 000 000"
              />
            </div>
          </div>

          <div>
            <label for="servicio" class="block text-sm font-medium text-gray-700 mb-2">Área de interés</label>
            <select
              id="servicio"
              name="servicio"
              class="w-full px-4 py-3 rounded-lg border border-gray-300 text-gray-900 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-colors bg-white"
            >
              <option value="">Seleccione un área...</option>
              <option value="mercantil">Derecho Mercantil</option>
              <option value="laboral">Derecho Laboral</option>
              <option value="inmobiliario">Derecho Inmobiliario</option>
              <option value="fiscal">Asesoría Fiscal</option>
              <option value="familia">Derecho de Familia</option>
              <option value="internacional">Derecho Internacional</option>
              <option value="otro">Otro</option>
            </select>
          </div>

          <div>
            <label for="mensaje" class="block text-sm font-medium text-gray-700 mb-2">Mensaje *</label>
            <textarea
              id="mensaje"
              name="mensaje"
              rows="4"
              required
              class="w-full px-4 py-3 rounded-lg border border-gray-300 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-colors resize-none"
              placeholder="Describa brevemente su consulta..."
            ></textarea>
          </div>

          <div class="flex items-start gap-3">
            <input
              type="checkbox"
              id="privacidad"
              name="privacidad"
              required
              class="mt-1 h-4 w-4 rounded border-gray-300 text-primary-700 focus:ring-primary-500"
            />
            <label for="privacidad" class="text-sm text-gray-600">
              He leído y acepto la
              <a href="#" class="text-primary-700 hover:underline">política de privacidad</a>
              y el tratamiento de mis datos personales.
            </label>
          </div>

          <button type="submit" class="btn-primary w-full justify-center py-3">
            Enviar consulta
          </button>

          <div id="form-success" class="hidden p-4 bg-green-50 border border-green-200 rounded-lg text-green-800 text-sm">
            ✓ Mensaje enviado correctamente. Nos pondremos en contacto con usted en breve.
          </div>
          <div id="form-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-lg text-red-800 text-sm">
            Ha ocurrido un error al enviar el formulario. Por favor, inténtelo de nuevo o contáctenos por teléfono.
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    successMsg?.classList.add('hidden');
    errorMsg?.classList.add('hidden');

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    // Placeholder: replace with actual form submission endpoint
    try {
      successMsg?.classList.remove('hidden');
      form.reset();
    } catch {
      errorMsg?.classList.remove('hidden');
    }
  });
</script>

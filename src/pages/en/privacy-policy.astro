---
import MainLayout from '@layouts/MainLayout.astro';
import LegalPage from '@components/LegalPage.astro';
import PrivacyPolicyContent from '@components/PrivacyPolicyContent.astro';
import {
  privacyPolicyUpdated,
  privacyPolicyUpdatedLabel,
} from '@i18n/legal/privacy-policy';
---

<MainLayout
  lang="en"
  title="Privacy policy"
  description="Privacy policy of Zurano y Blázquez. Information on how we process personal data collected through zuranoyblazquez.com."
  noindex={true}
>
  <LegalPage
    title="Privacy policy"
    updated={privacyPolicyUpdated.en}
    updatedLabel={privacyPolicyUpdatedLabel.en}
  >
    <PrivacyPolicyContent locale="en" />
  </LegalPage>
</MainLayout>

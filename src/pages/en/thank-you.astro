---
import MainLayout from '../../layouts/MainLayout.astro';
import Hero from '../../components/Hero.astro';
import { site } from '../../data/site.js';
import { getUi } from '../../i18n/ui.ts';

const t = getUi('en').thankYou;
---

<MainLayout lang="en" title={t.metaTitle} description={t.metaDescription} noindex={true}>
  <Hero
    eyebrow={t.eyebrow}
    align="center"
    subtitle={t.heroSubtitle}
    primaryCta={{ label: t.primaryCta, href: '/en/' }}
    secondaryCta={{ label: t.secondaryCta, href: '/en/services/' }}
  >
    <h1>{t.heroTitle}</h1>
  </Hero>

  <section class="section">
    <div class="container container--narrow thank-you">
      <p class="lead">
        If your enquiry is urgent, you can also call us on
        <a href={`tel:${site.phoneHref}`}>{site.phone}</a> or email us at
        <a href={`mailto:${site.email}`}>{site.email}</a>.
      </p>
    </div>
  </section>
</MainLayout>

<style>
  .thank-you {
    text-align: center;
  }
</style>

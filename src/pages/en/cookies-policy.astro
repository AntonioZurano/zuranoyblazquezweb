---
import MainLayout from '@layouts/MainLayout.astro';
import LegalPage from '@components/LegalPage.astro';
import CookiesPolicyContent from '@components/CookiesPolicyContent.astro';
import {
  cookiesPolicyUpdated,
  cookiesPolicyUpdatedLabel,
} from '@i18n/legal/cookies-policy';
---

<MainLayout
  lang="en"
  title="Cookies policy"
  description="Cookies policy of Zurano y Blazquez. Information about local storage used on zuranoyblazquez.com."
  noindex={true}
>
  <LegalPage
    title="Cookies policy"
    updated={cookiesPolicyUpdated.en}
    updatedLabel={cookiesPolicyUpdatedLabel.en}
  >
    <CookiesPolicyContent locale="en" />
  </LegalPage>
</MainLayout>

---
import MainLayout from '@layouts/MainLayout.astro';
import LegalPage from '@components/LegalPage.astro';
import LegalNoticeContent from '@components/LegalNoticeContent.astro';
import {
  legalNoticeUpdated,
  legalNoticeUpdatedLabel,
} from '@i18n/legal/legal-notice';
---

<MainLayout
  lang="en"
  title="Legal notice"
  description="Legal notice for Zurano y Blazquez. Information about the owner of zuranoyblazquez.com and terms of use."
  noindex={true}
>
  <LegalPage
    title="Legal notice"
    updated={legalNoticeUpdated.en}
    updatedLabel={legalNoticeUpdatedLabel.en}
  >
    <LegalNoticeContent locale="en" />
  </LegalPage>
</MainLayout>

---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import { site, contactForm } from '../data/site.js';
---

<MainLayout
  title="Contacto"
  description="Ponte en contacto con Zurano y Blazquez. Cuéntanos qué necesita tu empresa y te asesoramos sobre Microsoft 365, STEL Order, páginas web, hosting y soporte tecnológico."
>
  <Hero eyebrow="Contacto" subtitle="Cuéntanos qué necesita tu empresa y te responderemos lo antes posible, sin compromiso.">
    <h1>Hablemos de tu proyecto</h1>
  </Hero>

  <section class="section">
    <div class="container contact-grid">
      <!-- Información de contacto -->
      <aside class="contact-info">
        <h2 class="contact-info__title">Información de contacto</h2>
        <p>Estamos encantados de ayudarte. Elige la vía que prefieras:</p>
        <ul class="contact-info__list">
          <li>
            <span class="contact-info__icon" aria-hidden="true"><Icon name="mail" size={20} /></span>
            <div>
              <span class="contact-info__label">Correo electrónico</span>
              <a href={`mailto:${site.email}`}>{site.email}</a>
            </div>
          </li>
          <li>
            <span class="contact-info__icon" aria-hidden="true"><Icon name="phone" size={20} /></span>
            <div>
              <span class="contact-info__label">Teléfono</span>
              <a href={`tel:${site.phoneHref}`}>{site.phone}</a>
            </div>
          </li>
          <li>
            <span class="contact-info__icon" aria-hidden="true"><Icon name="clock" size={20} /></span>
            <div>
              <span class="contact-info__label">Horario</span>
              <span>{site.schedule}</span>
            </div>
          </li>
        </ul>
      </aside>

      <!-- Formulario (visual, sin envío real todavía) -->
      <div class="contact-form-wrapper card">
        <h2 class="contact-form__title">Escríbenos</h2>
        <p class="contact-form__intro">Rellena el formulario y te responderemos lo antes posible.</p>

        <form class="contact-form" method="POST" action={contactForm.endpoint}>
          <!-- Configuración de Formsubmit (campos ocultos) -->
          <input type="hidden" name="_subject" value={contactForm.subject} />
          <input type="hidden" name="_next" value={contactForm.redirectTo} />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_template" value="table" />
          <!-- Honeypot antispam: debe permanecer vacío (oculto a personas) -->
          <div class="visually-hidden" aria-hidden="true">
            <label for="_honey">No rellenar este campo</label>
            <input type="text" id="_honey" name="_honey" tabindex="-1" autocomplete="off" />
          </div>

          <div class="form-row">
            <div class="form-field">
              <label for="nombre">Nombre y apellidos *</label>
              <input type="text" id="nombre" name="nombre" autocomplete="name" required />
            </div>
            <div class="form-field">
              <label for="empresa">Empresa</label>
              <input type="text" id="empresa" name="empresa" autocomplete="organization" />
            </div>
          </div>

          <div class="form-row">
            <div class="form-field">
              <label for="email">Correo electrónico *</label>
              <input type="email" id="email" name="email" autocomplete="email" required />
            </div>
            <div class="form-field">
              <label for="telefono">Teléfono</label>
              <input type="tel" id="telefono" name="telefono" autocomplete="tel" />
            </div>
          </div>

          <div class="form-field">
            <label for="servicio">¿Sobre qué servicio quieres información?</label>
            <select id="servicio" name="servicio">
              <option value="">Selecciona una opción</option>
              <option value="microsoft-365">Microsoft 365</option>
              <option value="stel-order">STEL Order</option>
              <option value="paginas-web">Páginas web</option>
              <option value="dominios-hosting-correo">Dominios, hosting y correo</option>
              <option value="soporte-tecnologico">Soporte tecnológico</option>
              <option value="soluciones-para-empresas">Soluciones para empresas</option>
              <option value="otro">Otro</option>
            </select>
          </div>

          <div class="form-field">
            <label for="mensaje">Mensaje *</label>
            <textarea id="mensaje" name="mensaje" rows="5" required></textarea>
          </div>

          <div class="form-field form-field--check">
            <input type="checkbox" id="privacidad" name="privacidad" required />
            <label for="privacidad">
              He leído y acepto la <a href="/politica-de-privacidad/">política de privacidad</a>. *
            </label>
          </div>

          <button type="submit" class="btn btn--primary contact-form__submit">Enviar mensaje</button>

          <p class="form-note">
            Al enviar, aceptas que tratemos tus datos para responder a tu consulta. También puedes
            escribirnos a <a href={`mailto:${site.email}`}>{site.email}</a>.
          </p>
        </form>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.4fr;
    gap: var(--space-6);
    align-items: start;
  }

  /* Información de contacto */
  .contact-info__title {
    font-size: var(--fs-lg);
    margin-bottom: var(--space-3);
  }

  .contact-info__list {
    list-style: none;
    padding: 0;
    margin: var(--space-4) 0 0;
    display: grid;
    gap: var(--space-4);
  }

  .contact-info__list li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
  }

  .contact-info__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-sm);
    background: var(--color-bg-alt);
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .contact-info__label {
    display: block;
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  /* Formulario */
  .contact-form__title {
    font-size: var(--fs-lg);
    margin-bottom: var(--space-2);
  }

  .contact-form__intro {
    font-size: var(--fs-sm);
    margin-bottom: var(--space-4);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .form-field label {
    font-size: var(--fs-sm);
    font-weight: 600;
    color: var(--color-text);
  }

  .form-field input,
  .form-field select,
  .form-field textarea {
    font: inherit;
    font-size: var(--fs-sm);
    color: var(--color-text);
    padding: 0.7rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-soft);
    transition: border-color var(--transition), box-shadow var(--transition);
    width: 100%;
  }

  .form-field input:focus,
  .form-field select:focus,
  .form-field textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(10, 77, 140, 0.12);
    background: #fff;
  }

  .form-field textarea {
    resize: vertical;
  }

  .form-field--check {
    flex-direction: row;
    align-items: flex-start;
    gap: var(--space-2);
  }

  .form-field--check input {
    width: auto;
    margin-top: 0.2rem;
  }

  .form-field--check label {
    font-weight: 400;
    color: var(--color-text-soft);
    font-size: var(--fs-sm);
  }

  .contact-form__submit {
    width: 100%;
  }

  .form-note {
    margin-top: var(--space-4);
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-alt);
    border-left: 3px solid var(--color-accent);
    border-radius: var(--radius-sm);
    font-size: var(--fs-sm);
    color: var(--color-text-soft);
  }

  @media (max-width: 820px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }

    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>

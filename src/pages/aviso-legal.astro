---
import MainLayout from '@layouts/MainLayout.astro';
import LegalPage from '@components/LegalPage.astro';
import LegalNoticeContent from '@components/LegalNoticeContent.astro';
import {
  legalNoticeUpdated,
  legalNoticeUpdatedLabel,
} from '@i18n/legal/legal-notice';
---

<MainLayout
  title="Aviso legal"
  description="Aviso legal de Zurano y Blazquez. Información sobre el titular del sitio web zuranoyblazquez.com y las condiciones de uso."
  noindex={true}
>
  <LegalPage
    title="Aviso legal"
    updated={legalNoticeUpdated.es}
    updatedLabel={legalNoticeUpdatedLabel.es}
  >
    <LegalNoticeContent locale="es" />
  </LegalPage>
</MainLayout>

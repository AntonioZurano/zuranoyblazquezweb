---
import MainLayout from '@layouts/MainLayout.astro';
import LegalPage from '@components/LegalPage.astro';
import CookiesPolicyContent from '@components/CookiesPolicyContent.astro';
import {
  cookiesPolicyUpdated,
  cookiesPolicyUpdatedLabel,
} from '@i18n/legal/cookies-policy';
---

<MainLayout
  title="Política de cookies"
  description="Política de cookies de Zurano y Blazquez. Información sobre el uso de almacenamiento local en el sitio web zuranoyblazquez.com."
  noindex={true}
>
  <LegalPage
    title="Política de cookies"
    updated={cookiesPolicyUpdated.es}
    updatedLabel={cookiesPolicyUpdatedLabel.es}
  >
    <CookiesPolicyContent locale="es" />
  </LegalPage>
</MainLayout>

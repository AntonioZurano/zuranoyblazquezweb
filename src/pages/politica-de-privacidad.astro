---
import MainLayout from '@layouts/MainLayout.astro';
import LegalPage from '@components/LegalPage.astro';
import PrivacyPolicyContent from '@components/PrivacyPolicyContent.astro';
import {
  privacyPolicyUpdated,
  privacyPolicyUpdatedLabel,
} from '@i18n/legal/privacy-policy';
---

<MainLayout
  title="Política de privacidad"
  description="Política de privacidad de Zurano y Blazquez. Información sobre el tratamiento de datos personales y los derechos de los usuarios."
  noindex={true}
>
  <LegalPage
    title="Política de privacidad"
    updated={privacyPolicyUpdated.es}
    updatedLabel={privacyPolicyUpdatedLabel.es}
  >
    <PrivacyPolicyContent locale="es" />
  </LegalPage>
</MainLayout>

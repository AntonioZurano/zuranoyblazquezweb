---
import MainLayout from '../../layouts/MainLayout.astro';
import ServiceDetail from '../../components/ServiceDetail.astro';

const benefits = [
  'Asistencia técnica cercana y en español',
  'Resolución ágil de incidencias del día a día',
  'Mantenimiento proactivo para evitar problemas',
  'Un único interlocutor para toda tu tecnología',
  'Tranquilidad para centrarte en tu negocio',
];

const features = [
  { icon: 'support', title: 'Soporte remoto', text: 'Resolvemos la mayoría de incidencias de forma remota, rápida y sin desplazamientos.' },
  { icon: 'clock', title: 'Respuesta ágil', text: 'Atención rápida cuando algo no funciona, para minimizar el tiempo de parada.' },
  { icon: 'shield', title: 'Mantenimiento proactivo', text: 'Revisiones y actualizaciones para anticiparnos a los problemas antes de que ocurran.' },
  { icon: 'server', title: 'Equipos y red', text: 'Ayuda con ordenadores, impresoras, correo, copias de seguridad y conectividad.' },
  { icon: 'check', title: 'Acompañamiento', text: 'Te asesoramos en tus decisiones tecnológicas con un lenguaje claro y cercano.' },
  { icon: 'enterprise', title: 'Soporte a medida', text: 'Planes adaptados a las necesidades y al tamaño de tu empresa.' },
];

const faq = [
  { question: '¿Atendéis incidencias puntuales?', answer: 'Sí. Puedes contar con nosotros tanto para incidencias puntuales como para un mantenimiento continuo.' },
  { question: '¿El soporte es remoto o presencial?', answer: 'La mayoría de incidencias se resuelven en remoto. Cuando es necesario, valoramos la mejor forma de ayudarte.' },
  { question: '¿Trabajáis con empresas pequeñas?', answer: 'Por supuesto. Damos soporte a autónomos, comercios y pymes adaptando el servicio a cada caso.' },
];
---

<MainLayout
  title="Soporte tecnológico para empresas"
  description="Soporte tecnológico cercano y mantenimiento proactivo para pymes y autónomos. Zurano y Blazquez resuelve tus incidencias y cuida tu tecnología para que trabajes sin interrupciones."
>
  <ServiceDetail
    eyebrow="Soporte tecnológico"
    h1="Soporte tecnológico cercano para que todo funcione"
    subtitle="Asistencia técnica ágil y mantenimiento proactivo. Cuidamos tu tecnología para que tú te ocupes de tu negocio."
    introTitle="Tu departamento de informática de confianza"
    introText="Cuando algo falla, necesitas una solución rápida y sin tecnicismos. Te ofrecemos soporte cercano y mantenimiento preventivo para que tu tecnología funcione de forma estable y tú puedas concentrarte en lo que de verdad importa."
    benefits={benefits}
    features={features}
    faq={faq}
  />
</MainLayout>
